rules_version = '2';

// ⚠️ IMPORTANTE: esta app no tiene un sistema real de "inicio de sesión" para
// el administrador (el PIN del panel admin solo vive en el código de la
// aplicación, no en el servidor). Por eso estas reglas permiten leer y
// escribir a cualquiera con el enlace — es el mismo nivel de protección que
// tenía dentro de Claude. Si más adelante quieres protección real, hay que
// agregar Firebase Authentication y restringir "write" a un usuario admin
// autenticado. Por ahora, estas reglas dejan la tienda funcionando igual
// que antes, ni más ni menos segura.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
